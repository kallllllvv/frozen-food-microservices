{
  "name": "frozen-food-microservices",
  "version": "1.0.0",
  "description": "Tugas Web Astro Frozen Food",
  "main": "index.js",
  "scripts": {
    "start": "concurrently -c \"cyan,green\" -n \"BACKEND,FRONTEND\" \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend-server && node index.js",
    "dev:frontend": "cd frontend-web && npm run dev"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}